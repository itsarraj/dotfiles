#!/usr/bin/env bash

set -euo pipefail

roots=("$HOME/work" "$HOME/personal" "$HOME")
max_depth="${TMUX_SESSIONIZER_DEPTH:-2}"
skim_preview_window='right:60%:wrap:hidden'
skim_preview_bind='ctrl-p:toggle-preview,ctrl-/:change-preview-window(right:60%:wrap|down:45%:wrap|hidden)'

usage() {
  printf 'Usage: tmux-sessionizer [directory]\n'
}

session_name() {
  local name checksum
  name=$(basename "$1")
  name=${name//./_}
  name=${name//[^A-Za-z0-9_-]/_}

  # Avoid collisions for projects with the same basename in different roots.
  read -r checksum _ < <(printf '%s' "$1" | cksum)
  printf '%s_%s' "$name" "${checksum:0:5}"
}

list_dirs() {
  local existing_roots=()

  for root in "${roots[@]}"; do
    [[ -d $root ]] && existing_roots+=("$root")
  done

  if ((${#existing_roots[@]} == 0)); then
    return 0
  fi

  if command -v fd >/dev/null 2>&1; then
    fd . "${existing_roots[@]}" \
      --type d \
      --max-depth "$max_depth" \
      --hidden \
      --exclude .git \
      --exclude node_modules \
      --exclude .cache
  else
    find "${existing_roots[@]}" \
      -mindepth 0 \
      -maxdepth "$max_depth" \
      -type d \
      -not -path '*/.git/*' \
      -not -path '*/node_modules/*' \
      -not -path '*/.cache/*'
  fi
}

preview_dir() {
  local dir=$1

  printf '%s\n\n' "$dir"

  if git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf 'Git\n'
    git -C "$dir" status --short --branch 2>/dev/null | sed -n '1,12p'
    printf '\n'
  fi

  printf 'Files\n'
  if command -v eza >/dev/null 2>&1; then
    eza --tree --level=2 --git-ignore "$dir" 2>/dev/null | sed -n '1,40p'
  elif command -v tree >/dev/null 2>&1; then
    tree -L 2 -a -I '.git|node_modules|.cache' "$dir" 2>/dev/null | sed -n '1,40p'
  else
    ls -la "$dir" 2>/dev/null | sed -n '1,40p'
  fi
}

if [[ ${1:-} == -h || ${1:-} == --help ]]; then
  usage
  exit 0
fi

if [[ ${1:-} == --preview ]]; then
  preview_dir "${2:-}"
  exit 0
fi

if [[ $# -eq 1 ]]; then
  selected=$1
else
  if ! command -v sk >/dev/null 2>&1; then
    printf 'tmux-sessionizer: skim (sk) is required for interactive mode\n' >&2
    exit 1
  fi

  selected=$(
    list_dirs | sk \
      --prompt='session > ' \
      --bind="$skim_preview_bind" \
      --header='enter: switch/create | ctrl-p: preview | ctrl-/: layout | esc: cancel' \
      --preview="$0 --preview {}" \
      --preview-window="$skim_preview_window"
  ) || true
fi

if [[ -z $selected ]]; then
  exit 0
fi

selected=$(realpath "$selected")
if [[ ! -d $selected ]]; then
  printf 'tmux-sessionizer: not a directory: %s\n' "$selected" >&2
  exit 1
fi

selected_name=$(session_name "$selected")

if [[ -z ${TMUX:-} ]] && ! tmux info >/dev/null 2>&1; then
  tmux new-session -s "$selected_name" -c "$selected"
  exit 0
fi

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
  tmux new-session -ds "$selected_name" -c "$selected"
fi

if [[ -n ${TMUX:-} ]]; then
  tmux switch-client -t "$selected_name"
else
  tmux attach-session -t "$selected_name"
fi
